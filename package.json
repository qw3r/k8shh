{
  "name": "gap-cli-secrets",
  "version": "0.1.0",
  "description": "Interactive Kubernetes secret editor (Ink/Yoga TUI).",
  "type": "module",
  "bin": {
    "gap-secrets": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "start": "tsx src/cli.tsx",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "fmt": "prettier --write ."
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "ink": "^7.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
